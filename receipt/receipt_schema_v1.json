{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prospect.receipt.v1",
  "title": "Prospect Receipt v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "receipt_id",
    "frontier",
    "claim",
    "kind",
    "subject",
    "producer",
    "submitter_identity",
    "artifacts",
    "evidence",
    "conditions",
    "verifier",
    "verification_requirements",
    "replay_metadata",
    "status",
    "replayability",
    "state_diff",
    "verdicts",
    "accepted"
  ],
  "properties": {
    "schema_version": {
      "const": "prospect.receipt.v1"
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^rcpt_[0-9a-f]{16}$"
    },
    "frontier": {
      "type": "string",
      "minLength": 1
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "producer": {
      "type": "object",
      "minProperties": 1
    },
    "submitter_identity": {
      "type": "object",
      "minProperties": 1
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "sha256"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{16,64}$|^absent$"
          },
          "locator": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fact", "value", "source"],
        "properties": {
          "fact": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verifier": {
      "type": "object",
      "required": ["name", "method", "replay"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "replay": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "verification_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "replay_metadata": {
      "type": "object",
      "required": ["command", "verifier", "replayability", "frontier"],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "verifier": {
          "type": "string",
          "minLength": 1
        },
        "replayability": {
          "enum": ["exact", "reanalysis", "attested", "none"]
        },
        "frontier": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "status": {
      "enum": [
        "claimed",
        "evidence_attached",
        "computationally_reproduced",
        "independently_reanalyzed",
        "contradicted",
        "refuted"
      ]
    },
    "replayability": {
      "enum": ["exact", "reanalysis", "attested", "none"]
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "state_diff": {
      "type": "object",
      "required": ["accepted", "model_can_apply", "effect"],
      "properties": {
        "accepted": {
          "type": "boolean"
        },
        "model_can_apply": {
          "const": false
        },
        "delta_id": {
          "type": "string"
        },
        "effect": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "verdicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gene", "typed_status"],
        "properties": {
          "gene": {"type": "string", "minLength": 1},
          "typed_status": {
            "enum": ["evidence_attached", "associative_only", "contradicted", "not_assayed"]
          },
          "comparability": {
            "enum": ["comparable", "orthogonal_phenotype", "not_declared"]
          }
        },
        "additionalProperties": true
      }
    },
    "executed_protocol": {
      "type": "object",
      "description": "Protocol, intervention, sample, conditions, and controls run by a lab producer.",
      "additionalProperties": true
    },
    "assay_readout": {
      "type": "object",
      "description": "Assay summary, required measurements, and result payload reference.",
      "additionalProperties": true
    },
    "affected_claims": {
      "type": "array",
      "description": "Receipts or accepted claims affected by this return receipt.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "reviewer_signature": {
      "type": "object",
      "description": "Human reviewer signature field for a returned lab receipt.",
      "additionalProperties": true
    },
    "acceptance": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": ["signer", "delta_id", "pubkey", "signature", "attestation_type", "covered_root"],
          "properties": {
            "signer": {
              "type": "string"
            },
            "delta_id": {
              "type": "string"
            },
            "pubkey": {
              "type": "string"
            },
            "signature": {
              "type": "string"
            },
            "attestation_type": {
              "const": "legacy_frontier_root_signature"
            },
            "covered_root": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "accepted": {
      "const": false,
      "description": "Receipt v1 is proposal-only. Acceptance is a separate human-signed event."
    }
  }
}
